ARG RUN_IMAGE=eclipse-temurin:25-jre-noble
FROM ${RUN_IMAGE} as builder

ARG APP_DIR=/opt/application
ARG JAR_DIR=build/libs
WORKDIR $APP_DIR

ADD $JAR_DIR/*.jar $APP_DIR/application.jar

RUN java -Djarmode=layertools -jar $APP_DIR/application.jar extract

FROM ${RUN_IMAGE} as runner

RUN apt update && \
    apt install -y curl

ARG APP_DIR=/opt/application
WORKDIR $APP_DIR
COPY --from=builder $APP_DIR/spring-boot-loader/ ./
COPY --from=builder $APP_DIR/snapshot-dependencies/ ./
COPY --from=builder $APP_DIR/dependencies/ ./
COPY --from=builder $APP_DIR/application/ ./

ARG DOCKER_USER=app
RUN groupadd -r $DOCKER_USER && useradd -rg $DOCKER_USER $DOCKER_USER
USER $DOCKER_USER

EXPOSE 8080/tcp
ENTRYPOINT ["java", \
            "-Dfile.encoding=UTF-8", \
            "-Xmx960M", \
            "-Xms960M", \
            "-XX:InitialCodeCacheSize=48M", \
            "-XX:ReservedCodeCacheSize=96M", \
            "-XX:+UseG1GC", \
            "org.springframework.boot.loader.launch.JarLauncher" ]